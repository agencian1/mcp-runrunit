# Runrun.it API (obrigatório para o MCP)
RUNRUNIT_APP_KEY=
RUNRUNIT_USER_TOKEN=

# Cloudinary (opcional; usado pelas skills de evidências/upload de imagens)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Discord (opcional; usado pelas tools runrunit_discord_* para histórico por projeto / 1 canal por cliente)
# Token: use BOT_RUNRUNIT_REPORT ou BOT_RUNRUNIT_REPORT_PRIVATE_KEY
BOT_RUNRUNIT_REPORT=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=

# GitHub (opcional; runrunit_share_cursor_agent / runrunit_share_cursor_skill)
# Configure only on the MCP server host (Cursor MCP config, CI secrets). Never commit real tokens.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# Optional; default main
GITHUB_BASE_BRANCH=

# Sentry (opcional; monitoramento de erros)
# Em produção/staging, recomenda-se definir no host do MCP/CI (não comitar valores reais)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_ENABLED=true
SENTRY_ERROR_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
